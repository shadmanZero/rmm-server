{
  "name": "rackoona-server",
  "version": "0.1.0",
  "private": true,
  "description": "rackoona RMM control plane — zero-touch enroll, control channel, relay byte-pipe, and the noVNC web frontend",
  "license": "MIT",
  "scripts": {
    "vendor:novnc": "node scripts/vendor-novnc.js",
    "build:css": "tailwindcss -i ./src/styles/app.css -o ./public/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/app.css -o ./public/styles.css --watch",
    "build": "npm run build:css && tsc -p .",
    "prestart": "node scripts/vendor-novnc.js && npm run build:css",
    "start": "node dist/index.js",
    "dev": "node scripts/vendor-novnc.js && npm run build:css && tsx watch src/index.ts",
    "typecheck": "tsc -p . --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "db:pull": "drizzle-kit pull",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:deploy": "node dist/db/migrate.js"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "postgres": "^3.4.9",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@novnc/novnc": "^1.7.0",
    "@tailwindcss/cli": "^4.3.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
