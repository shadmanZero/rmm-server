# rackoona control plane — configuration (all optional; sane defaults shown)

# Where to listen.
HOST=0.0.0.0
PORT=4000

# Public base URL the agent and browser should use to reach this server.
# Leave blank on localhost (URLs are derived from the request Host header and
# X-Forwarded-Proto, so it works behind nginx automatically). On a VPS behind a
# TLS reverse proxy, set this to your domain so emitted URLs use wss:// / https://
#   PUBLIC_URL=https://rmm.example.com
PUBLIC_URL=

# Trust X-Forwarded-* headers (set true when behind nginx/Caddy; default true).
TRUST_PROXY=true

# Heartbeat cadence the agent is told to use, in seconds.
HEARTBEAT_INTERVAL=25

# How long a freshly minted session waits for both sides to pair, in seconds.
SESSION_TTL=60

# Informational tenant id stamped onto enrolled devices.
TENANT_ID=default

# ─────────────────────────────────────────────────────────────────────
# Database (Drizzle) — REQUIRED
# ─────────────────────────────────────────────────────────────────────
# Postgres connection string. drizzle-kit (pull/generate/migrate) and the
# running server both read this. Use sslmode=disable for a plain port.
DATABASE_URL=postgres://user:password@host:5432/rmm?sslmode=disable

# ─────────────────────────────────────────────────────────────────────
# Dashboard authentication
# ─────────────────────────────────────────────────────────────────────
# REQUIRED: secret used to sign session cookies. Generate with:
#   openssl rand -hex 32
# Rotating this value invalidates every active login.
SESSION_SECRET=

# How long a login stays valid, in hours (default 168 = 7 days).
SESSION_TTL_HOURS=168

# Force the Secure cookie flag. Leave unset to auto-enable when PUBLIC_URL is
# https. Keep it off for plain-http localhost so the cookie is actually stored.
# AUTH_COOKIE_SECURE=true

# Seed admin, created/updated by `npm run db:seed`. Username is case-insensitive.
AUTH_ADMIN_NAME=shadmanZero
AUTH_ADMIN_USERNAME=shadmanzero
AUTH_ADMIN_PASSWORD=change-me-before-seeding
